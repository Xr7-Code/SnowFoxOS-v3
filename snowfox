cmd_stream() {
    if ! command -v mpv &>/dev/null; then
        err "mpv nicht gefunden. Installieren: sudo apt install mpv"
        exit 1
    fi

    if [[ -z "$1" ]]; then
        err "Verwendung: snowfox stream <URL>"
